{
  "name": "vibevault-api",
  "version": "1.0.0",
  "description": "Vibe Vault Cloud API - Auth and Cloud Backup",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create vibevault-db",
    "db:migrate": "wrangler d1 migrations apply vibevault-db",
    "db:schema": "wrangler d1 execute vibevault-db --file=./schema.sql"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20240129.0"
  },
  "devDependencies": {
    "wrangler": "^3.28.0",
    "typescript": "^5.3.0"
  }
}
